        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>政务列表</td><td>查看、审核、置顶、编辑</td><td>业务层面选项、级别选项</td></tr>
            <tr><td>业务层面管理</td><td>增删改业务层面选项</td><td>名称、排序、状态</td></tr>
            <tr><td>级别代号管理</td><td>增删改级别代号</td><td>名称、排序、状态</td></tr>
            <tr><td>熟悉程度管理</td><td>增删改熟悉程度</td><td>名称、排序、状态</td></tr>
        </tbody></table>
        
        <h3>2.6 案例管理</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>成功案例列表</td><td>查看、审核、置顶、编辑</td><td>排序方式</td></tr>
            <tr><td>避坑指南列表</td><td>查看、审核、置顶、编辑</td><td>排序方式</td></tr>
            <tr><td>富文本编辑</td><td>案例内容编辑</td><td>编辑器配置</td></tr>
        </tbody></table>
        
        <h3>2.7 基础数据管理</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>行业分类</td><td>增删改行业</td><td>名称（限4汉字）、排序、状态</td></tr>
            <tr><td>城市数据</td><td>导入/更新行政区划</td><td>省市区县乡镇数据</td></tr>
            <tr><td>部门选项</td><td>增删改部门</td><td>名称、排序、状态</td></tr>
            <tr><td>业务类型</td><td>增删改求助业务类型</td><td>名称、排序、状态</td></tr>
            <tr><td>有效期选项</td><td>配置有效期选项</td><td>天数、显示名称</td></tr>
        </tbody></table>
        
        <h3>2.8 首页配置管理</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>Logo管理</td><td>上传/更换Logo</td><td>Logo图片、尺寸</td></tr>
            <tr><td>文案管理</td><td>修改主标题、副标题、slogan</td><td>所有前端文案</td></tr>
            <tr><td>广告横幅</td><td>管理滚动广告</td><td>文案、链接、状态</td></tr>
            <tr><td>一级菜单</td><td>增删改菜单项、排序</td><td>菜单名称、路由、状态</td></tr>
            <tr><td>行业分类</td><td>管理左侧分类</td><td>分类名称、排序</td></tr>
        </tbody></table>
        
        <h3>2.9 系统设置</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>会员等级</td><td>配置会员价格、权益</td><td>价格、权益列表</td></tr>
            <tr><td>分成比例</td><td>设置引荐分成比例</td><td>一级比例、二级比例</td></tr>
            <tr><td>阶梯奖励</td><td>配置引荐阶梯规则</td><td>阶梯阈值、奖励</td></tr>
            <tr><td>提现设置</td><td>配置提现规则</td><td>最低提现金额、手续费</td></tr>
            <tr><td>审核开关</td><td>设置哪些内容需要审核</td><td>各模块审核开关</td></tr>
        </tbody></table>
        
        <h3>2.10 消息管理</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>消息模板</td><td>管理系统消息模板</td><td>模板内容、变量</td></tr>
            <tr><td>消息发送</td><td>手动发送消息（指定用户/全部）</td><td>收件人、内容</td></tr>
            <tr><td>定时任务</td><td>设置自动发送规则</td><td>触发条件、模板</td></tr>
        </tbody></table>
        
        <h3>2.11 风控看板</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>异常检测</td><td>检测异常引荐、刷单行为</td><td>检测规则阈值</td></tr>
            <tr><td>敏感词管理</td><td>维护敏感词库</td><td>敏感词列表、替换词</td></tr>
            <tr><td>操作日志</td><td>查看管理员操作</td><td>日志筛选、导出</td></tr>
        </tbody></table>
        
        <h3>2.12 数据字典管理</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>前端所有文案</td><td>集中管理所有页面文案</td><td>键值对配置</td></tr>
            <tr><td>状态标签</td><td>管理各种状态标签颜色、文案</td><td>状态值、颜色、文案</td></tr>
            <tr><td>按钮文案</td><td>管理所有操作按钮文案</td><td>按钮名称、提示语</td></tr>
            <tr><td>错误提示</td><td>管理系统错误提示信息</td><td>错误码、提示语</td></tr>
        </tbody></table>
        
        <h2>三、前后端数据字典配置表（SQL）</h2>
        <pre>-- 前端文案配置表
CREATE TABLE `frontend_texts` (
  `id` int NOT NULL AUTO_INCREMENT,
  `page` varchar(50) NOT NULL COMMENT '页面标识',
  `element` varchar(50) NOT NULL COMMENT '元素标识',
  `text` varchar(255) NOT NULL COMMENT '文案内容',
  `description` varchar(255) DEFAULT NULL COMMENT '说明（哪个位置的文案）',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_page_element` (`page`,`element`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='前端文案配置';

-- Logo配置表
CREATE TABLE `site_logo` (
  `id` int NOT NULL AUTO_INCREMENT,
  `logo_url` varchar(255) NOT NULL COMMENT 'Logo图片地址',
  `logo_mobile` varchar(255) DEFAULT NULL COMMENT '手机端Logo（可选）',
  `logo_desktop` varchar(255) DEFAULT NULL COMMENT '电脑端Logo（可选）',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='站点Logo配置';

-- 一级菜单配置表
CREATE TABLE `home_menus` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(50) NOT NULL COMMENT '菜单名称',
  `route` varchar(100) NOT NULL COMMENT '路由地址',
  `icon` varchar(50) DEFAULT NULL COMMENT '图标',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='首页一级菜单配置';

-- 广告横幅配置表
CREATE TABLE `ad_banners` (
  `id` int NOT NULL AUTO_INCREMENT,
  `text` varchar(255) NOT NULL COMMENT '广告文案',
  `link` varchar(255) DEFAULT NULL COMMENT '跳转链接',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `created_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='广告横幅配置';

-- 行业分类配置表
CREATE TABLE `industry_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(12) NOT NULL COMMENT '行业名称（限4汉字）',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='行业分类配置';

-- 部门选项配置表
CREATE TABLE `department_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(50) NOT NULL COMMENT '部门名称',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='部门选项配置';

-- 政务业务层面配置表
CREATE TABLE `gov_business_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(50) NOT NULL COMMENT '业务层面名称',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='政务业务层面配置';

-- 级别代号配置表
CREATE TABLE `gov_level_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(20) NOT NULL COMMENT '级别代号（如A级）',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='级别代号配置';

-- 熟悉程度配置表
CREATE TABLE `familiarity_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(20) NOT NULL COMMENT '熟悉程度（一般/熟悉/很熟）',
  `icon` varchar(10) DEFAULT NULL COMMENT '图标（如★）',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='熟悉程度配置';

-- 有效期选项配置表
CREATE TABLE `expire_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(50) NOT NULL COMMENT '显示名称（如1个月）',
  `days` int NOT NULL COMMENT '天数',
  `type` varchar(20) NOT NULL COMMENT '类型（群码/项目/政务等）',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `status` tinyint NOT NULL DEFAULT '1' COMMENT '1-启用 0-禁用',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='有效期选项配置';

-- 状态标签配置表
CREATE TABLE `status_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `type` varchar(50) NOT NULL COMMENT '状态类型（如群码状态/引荐状态）',
  `value` varchar(50) NOT NULL COMMENT '状态值',
  `text` varchar(50) NOT NULL COMMENT '显示文案',
  `color` varchar(20) NOT NULL COMMENT '颜色（如#1e7e34）',
  `bg_color` varchar(20) DEFAULT NULL COMMENT '背景色',
  `sort` int NOT NULL DEFAULT '0' COMMENT '排序',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='状态标签配置';

-- 按钮文案配置表
CREATE TABLE `button_config` (
  `id` int NOT NULL AUTO_INCREMENT,
  `page` varchar(50) NOT NULL COMMENT '页面标识',
  `button_id` varchar(50) NOT NULL COMMENT '按钮标识',
  `text` varchar(50) NOT NULL COMMENT '按钮文案',
  `action` varchar(100) DEFAULT NULL COMMENT '操作说明',
  `updated_at` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_page_button` (`page`,`button_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='按钮文案配置';
        </pre>
        
        <h2>四、后台管理界面预览（核心配置页）</h2>
        <p style="background:#f0f0f0; padding:16px; border-radius:12px; margin:20px 0;">
            ⚠️ 注：此处为后台管理界面的HTML预览代码，已包含在文档中。实际使用时可直接复制到后台管理项目中。
        </p>
        
        <h2>五、更新说明与文件替换指南</h2>
        
        <h3>5.1 文件替换指南</h3>
        <table>
            <tbody><tr><th style="width:30%">功能模块</th><th style="width:40%">需要替换的文件</th><th style="width:30%">备份建议</th></tr>
            <tr><td>Logo配置</td><td>config/logo.json 或数据库 site_logo 表</td><td>备份原图片文件</td></tr>
            <tr><td>文案配置</td><td>config/texts.json 或数据库 frontend_texts 表</td><td>导出原配置</td></tr>
            <tr><td>菜单配置</td><td>config/menus.json 或数据库 home_menus 表</td><td>备份原菜单数据</td></tr>
            <tr><td>行业分类</td><td>数据库 industry_config 表</td><td>导出原数据</td></tr>
            <tr><td>状态标签</td><td>数据库 status_config 表</td><td>导出原数据</td></tr>
        </tbody></table>
        
        <h3>5.2 配置文件示例</h3>
        <pre>// config/texts.json 示例
{
  "home": {
    "main_title": "全国人脉二维码聚合平台",
    "sub_title": "找群 · 找项目 · 找人脉",
    "slogan": "上传你的资源，发现你的机会，让每一次连接都产生价值",
    "ad_text": "✨ 让连接自然发生，让价值持续流动"
  },
  "buttons": {
    "publish": "发布",
    "contact": "查看联系方式",
    "refer": "推荐给朋友"
  },
  "labels": {
    "supply": "供",
    "demand": "需",
    "pending": "待审核",
    "active": "有效",
    "expired": "已失效"
  }
}
        </pre>
        
        <h2>六、操作说明</h2>
        
        <h3>6.1 如何修改前端内容</h3>
        <ul>
            <li><strong>修改Logo：</strong> 进入后台管理 → 首页配置 → Logo管理，上传新Logo图片，系统自动替换。手机端和电脑端可分别设置不同尺寸。</li>
            <li><strong>修改文案：</strong> 进入后台管理 → 首页配置 → 文案管理，找到对应页面的文案输入框，修改后点击保存，前端自动更新。</li>
            <li><strong>修改菜单：</strong> 进入后台管理 → 首页配置 → 一级菜单，可增删改菜单项，拖拽排序，禁用状态菜单不显示。</li>
            <li><strong>修改下拉选项：</strong> 进入对应基础数据管理页面，增删改选项，前端发布页自动同步。</li>
        </ul>
        
        <h3>6.2 注意事项</h3>
        <ul>
            <li>每次修改前建议备份原数据</li>
            <li>修改后立即预览确认效果</li>
            <li>如遇问题可回滚备份</li>
            <li>所有配置文件独立，不影响其他功能</li>
        </ul>
        
