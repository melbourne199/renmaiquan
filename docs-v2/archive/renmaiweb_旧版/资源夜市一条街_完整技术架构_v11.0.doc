            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>群码列表</td><td>查看、搜索、筛选、审核、置顶</td><td>行业分类、状态筛选</td></tr>
            <tr><td>审核管理</td><td>通过/拒绝、填写审核意见</td><td>审核模板</td></tr>
            <tr><td>有效期管理</td><td>手动延长、批量设置</td><td>默认有效期天数</td></tr>
            <tr><td>引荐记录</td><td>查看群码引荐数据</td><td>引荐分成比例</td></tr>
        </tbody></table>
        
        <h3>2.4 企业资源管理</h3>
        <table>
            <tbody><tr><th>模块</th><th>功能</th><th>可配置项</th></tr>
            <tr><td>项目列表</td><td>查看、审核、置顶、编辑</td><td>行业选项、状态</td></tr>
            <tr><td>企业点赞列表</td><td>查看、审核、置顶、编辑</td><td>部门选项、地区选项</td></tr>
            <tr><td>求助列表</td><td>查看、审核、置顶、编辑</td><td>业务类型选项</td></tr>
            <tr><td>引荐管理</td><td>查看引荐记录、标记成交</td><td>分成比例配置</td></tr>
        </tbody></table>
        
