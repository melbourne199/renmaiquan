<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>资源夜市平台 · 商业人脉资源对接</title>
  <link rel="stylesheet" href="./style.css" />
</head>
<body>
  <div id="canvas-container"></div>

  <!-- 地球交互层 -->
  <div id="earth-interaction"></div>

  <div class="ui-overlay">
    <!-- 顶部导航 -->
    <div class="navbar">
      <div class="navbar-brand desktop-brand">
        <div class="navbar-brand-icon">🌌</div>
        资源夜市
      </div>
      <div class="desktop-nav-links">
        <div class="nav-item active">首页</div>
        <a class="nav-item" href="groups.html">行业群码</a>
        <a class="nav-item" href="gov-list.html">政企资源</a>
        <a class="nav-item" href="help-detail.html">最新求助</a>
        <a class="nav-item" href="finance.html">民企金融</a>
        <a class="nav-item" href="escort.html">居间护航</a>
        <a class="nav-item" href="case-list.html">资源案例</a>
      </div>
      <div class="navbar-menu-btn" id="menuBtn" onclick="toggleMenu()">
        <span></span><span></span><span></span>
      </div>
    </div>

    <!-- 菜单遮罩 -->
    <div class="navbar-menu-overlay" id="menuOverlay" onclick="toggleMenu()"></div>

    <!-- 菜单面板 -->
    <div class="navbar-menu-panel" id="menuPanel">
      <div class="nav-item active">首页</div>
      <a class="nav-item" href="groups.html">行业群码</a>
      <a class="nav-item" href="gov-list.html">政企资源</a>
      <a class="nav-item" href="help-detail.html">最新求助</a>
      <a class="nav-item" href="finance.html">民企金融</a>
      <a class="nav-item" href="escort.html">居间护航</a>
      <a class="nav-item" href="case-list.html">资源案例</a>
    </div>

    <!-- 主标题区 (header-banner) -->
    <div class="hero-section">
      <div class="hero-overlay"></div>
      <div class="hero-content header-banner">
        <div class="banner-title-wrap">
          <h1 class="hero-title">探索宇宙资源・共筑商业星河</h1>
        </div>
        <div class="banner-subtitle-wrap">
          <p class="hero-subtitle">让每一份资源，都在宇宙中发光</p>
        </div>
        <div class="banner-desc-wrap">
          <p class="hero-desc">将企业资源、人脉、项目与需求，汇入可搜索、可匹配、可脱敏的资源宇宙，<br>让高质量对接如星链般精准发生</p>
        </div>
      </div>
    </div>

    <!-- 搜索区 -->
    <div class="search-section">
      <input id="citySearch" type="text" placeholder="搜索你想要找的人或事" />
      <button id="searchBtn">探索</button>
    </div>

    <!-- 搜索提示 -->
    <p class="search-hint">数据实时更新・信息全程脱敏・服务合法合规</p>

    <!-- 城市tooltip -->
    <div id="cityTooltip" class="city-tooltip hidden"></div>

    <!-- 右侧数据卡片容器 -->
    <div class="right-panel">
      <!-- 总数卡片（默认显示） -->
      <div class="stats-panel">
        <div class="stats-header">
          <span class="stats-globe">🌍</span>
          <span class="stats-title">平台供需总览</span>
        </div>
        <div class="stats-card">
          <span>可对接资源</span>
          <strong id="statProvided">936 条</strong>
        </div>
        <div class="stats-card">
          <span>有效需求</span>
          <strong id="statHelp">127 条</strong>
        </div>
      </div>

      <!-- 城市详情卡片（点击城市后显示，在总数卡片上方） -->
      <div id="cityCard" class="city-card hidden">
        <div class="city-card-header">
          <span class="city-card-name" id="cardCityName">北京</span>
          <button class="city-card-close" onclick="closeCityCard()">×</button>
        </div>
        <div class="city-card-body">
          <div class="city-card-stat">
            <span class="stat-label">人脉提供</span>
            <span class="stat-value" id="cardProvided">126 个</span>
          </div>
          <div class="city-card-stat">
            <span class="stat-label">需要帮助</span>
            <span class="stat-value" id="cardHelp">18 个</span>
          </div>
          <div class="city-card-stat">
            <span class="stat-label">今日活跃</span>
            <span class="stat-value" id="cardActive">+23</span>
          </div>
        </div>
        <button class="city-card-btn" onclick="viewCityDetail()">查看详情</button>
      </div>

      <!-- 搜索结果弹窗 -->
      <div id="searchResultModal" class="search-modal hidden">
        <div class="search-modal-content">
          <div class="search-modal-header">
            <span class="search-modal-title">搜索结果</span>
            <button class="search-modal-close" onclick="closeSearchModal()">×</button>
          </div>
          <div class="search-modal-body">
            <div id="searchResultList" class="search-result-list"></div>
            <div id="searchNoResult" class="search-no-result hidden">
              <p>未找到符合条件的资源</p>
              <p class="search-no-result-hint">你可以发布一条需求，有人脉资源的用户会主动联系你</p>
              <div class="search-no-result-actions">
                <button class="search-btn-publish" onclick="goToPublishDemand()">发布需求</button>
                <button class="search-btn-cancel" onclick="closeSearchModal()">取消</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 会员二维码弹窗 -->
      <div id="qrCodeModal" class="qr-modal hidden">
        <div class="qr-modal-content">
          <div class="qr-modal-header">
            <span class="qr-modal-title">联系方式</span>
            <button class="qr-modal-close" onclick="closeQrModal()">×</button>
          </div>
          <div class="qr-modal-body">
            <div id="qrCodeImage" class="qr-code-image"></div>
            <p class="qr-code-hint">扫码添加对方微信</p>
          </div>
        </div>
      </div>

      <!-- 非会员提示弹窗 -->
      <div id="memberTipModal" class="member-tip-modal hidden">
        <div class="member-tip-content">
          <div class="member-tip-icon">🔒</div>
          <p class="member-tip-text">开通会员才能查看联系方式</p>
          <p class="member-tip-hint">会员专属权益，查看完整人脉资源</p>
          <div class="member-tip-actions">
            <button class="member-btn-open" onclick="goToRegister()">开通会员</button>
            <button class="member-btn-cancel" onclick="closeMemberTip()">取消</button>
          </div>
        </div>
      </div>
    </div>

    <!-- 底部功能卡片（发布入口） -->
    <div class="cards-container">
      <a href="publish-enterprise-supply.html" class="func-card">
        <h3>💼 企业资源对接</h3>
        <p>我朋友在XX企业XX部门。</p>
      </a>
      <a href="publish-enterprise-demand.html" class="func-card">
        <h3>🔍 需求人脉寻找</h3>
        <p>我需要找XX部门对接业务。</p>
      </a>
      <a href="publish-gov.html" class="func-card">
        <h3>🤝 部门渠道对接</h3>
        <p>我朋友在XX部门的XX岗。</p>
      </a>
      <a href="publish-case.html" class="func-card">
        <h3>🚀 优质项目发布</h3>
        <p>我有可行性项目，欢迎合作引荐。</p>
      </a>
    </div>

    <div class="footer-meta">
      <div class="record-placeholder">© 2026 资源夜市 · All Rights Reserved.　<a href="https://beian.miit.gov.cn/" target="_blank" style="color:inherit;text-decoration:underline;">粤ICP备2026032295号</a>　・　内容及观点仅代表发布者本人，用于资源展示与居间合作，不涉及公共议题讨论</div>
    </div>
  </div>

  <script>
  function toggleMenu() {
    const btn = document.getElementById('menuBtn');
    const panel = document.getElementById('menuPanel');
    const overlay = document.getElementById('menuOverlay');
    btn.classList.toggle('active');
    panel.classList.toggle('open');
    overlay.classList.toggle('open');
  }
  </script>
  <script type="importmap">
  {
    "imports": {
      "three": "./libs/three@0.160.0/build/three.module.js",
      "three/addons/": "./libs/three@0.160.0/examples/jsm/"
    }
  }
  </script>
  <script type="module" src="./script.js"></script>
</body>
</html>
